# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dmx_academy

# ── Service ───────────────────────────────────────────────────────────────────
PROCTOR_SERVICE_PORT=8001
PROCTOR_SERVICE_HOST=0.0.0.0
PROCTOR_WORKERS=4
QUEUE_CAPACITY=50
QUEUE_TIMEOUT_MS=500

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local              # local | s3 | disabled
LOCAL_STORAGE_PATH=uploads/proctor
IMAGE_RETENTION_DAYS=30
THUMBNAIL_MAX_WIDTH=640
THUMBNAIL_MAX_HEIGHT=360
THUMBNAIL_JPEG_QUALITY=75

# ── S3 (only if STORAGE_BACKEND=s3) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=dmx-proctor-frames

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_FACE_DETECTION=true
ENABLE_HEAD_POSE=true
ENABLE_MOUTH_DETECTION=true
ENABLE_LIGHTING_CHECK=true
ENABLE_BLUR_CHECK=true
ENABLE_AUDIO_MONITORING=false
STORE_FLAGGED_IMAGES=true

# ── Session Policy ────────────────────────────────────────────────────────────
NEW_SESSION_ON_RECONNECT=false
CALIBRATION_DURATION_S=15

# ── Detection Thresholds (overridable per-institute in DB) ────────────────────
LOOK_AWAY_SUSTAINED_S=5
YAW_WARNING_DEG=20
YAW_FLAG_DEG=30
YAW_HIGH_DEG=40
PITCH_WARNING_DEG=15
PITCH_FLAG_DEG=25
PITCH_HIGH_DEG=35
MAR_THRESHOLD=0.6
MAR_SUSTAINED_FRAMES=3
BLUR_THRESHOLD=100.0
LOW_LIGHT_THRESHOLD=50

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Auth (shared secret from Node.js backend) ────────────────────────────────
INTERNAL_API_SECRET=change-me-in-production
