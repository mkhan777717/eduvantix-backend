{
  "language": "go",
  "version": "1.21",
  "extension": "go",
  "sourceFile": "main.go",
  "executionMode": "compiled",
  "compile": {
    "command": "go",
    "args": ["build", "-o", "{outPath}", "{srcPath}"]
  },
  "run": {
    "command": "{outPath}",
    "args": []
  },
  "supports": {
    "functional": true,
    "class_design": true,
    "interactive": false,
    "threads": false,
    "stdin": true,
    "stdout": true
  },
  "runtimeLibraries": ["tree", "list", "graph"],
  "docker": {
    "image": "golang:1.21-alpine"
  },
  "dbLanguage": "GO",
  "imports": "import (\n\t\"bufio\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n\t\"container/list\"\n)",
  "inputVarTemplate": "line{idx}",
  "parameterReadTemplate": "var line{idx} string;\n    if scanner.Scan() {\n        line{idx} = scanner.Text();\n    }\n    {paramName} := {deserialize}",
  "executionCallTemplate": "result := {functionName}({paramNames})",
  "executionCallVoidTemplate": "{functionName}({paramNames})",
  "printTemplate": "fmt.Println({serializeExpr})",
  "mainBodyTemplate": "func main() {\n    scanner := bufio.NewScanner(os.Stdin)\n    buf := make([]byte, 1024*1024)\n    scanner.Buffer(buf, 1024*1024)\n    _ = strconv.Itoa(0)\n    _ = strings.TrimSpace(\"\")\n    _ = list.New()\n    {executionParts}\n    {printParts}\n    {cleanupParts}\n}",
  "runtimeLibraryCleanupRegexes": ["package\\s+main", "import\\s*\\(([\\s\\S]*?)\\)", "import\\s+\"[^\"]+\""]
}
