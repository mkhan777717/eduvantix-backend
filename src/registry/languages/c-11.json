{
  "language": "c",
  "version": "11",
  "extension": "c",
  "sourceFile": "main.c",
  "executionMode": "compiled",
  "compile": {
    "command": "gcc",
    "args": ["-O2", "-std=c11", "{srcPath}", "-o", "{outPath}", "-lm"]
  },
  "run": {
    "command": "{outPath}",
    "args": []
  },
  "supports": {
    "functional": true,
    "class_design": false,
    "interactive": false,
    "threads": false,
    "stdin": true,
    "stdout": true
  },
  "runtimeLibraries": ["tree", "list", "graph"],
  "docker": {
    "image": "gcc:14",
    "runImage": "gcc:14"
  },
  "dbLanguage": "C",
  "imports": "#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <stdbool.h>\n#include <ctype.h>",
  "inputVarTemplate": "line{idx}",
  "parameterReadTemplate": "{typeName} {paramName} = {deserialize};",
  "executionCallTemplate": "{returnTypeName} result = {functionName}({paramNames});",
  "executionCallVoidTemplate": "{functionName}({paramNames});",
  "printTemplate": "printf(\"%s\\n\", {serializeExpr});",
  "mainBodyTemplate": "int main() {\n    {executionParts}\n    {printParts}\n    {cleanupParts}\n    return 0;\n}",
  "runtimeLibraryCleanupRegexes": []
}
