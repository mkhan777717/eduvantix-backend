{
  "name": "FLOAT",
  "category": "primitive",
  "languages": {
    "cpp": {
      "typeName": "double",
      "deserialize": "stod({varName})",
      "serialize": "to_string({varName})"
    },
    "python": {
      "typeName": "float",
      "deserialize": "float({varName}.strip())",
      "serialize": "str({varName})"
    },
    "javascript": {
      "typeName": "number",
      "deserialize": "parseFloat({varName})",
      "serialize": "String({varName})"
    },
    "java": {
      "typeName": "double",
      "deserialize": "Double.parseDouble({varName}.trim())",
      "serialize": "String.valueOf({varName})"
    },
    "go": {
      "typeName": "float64",
      "deserialize": "func() float64 { val, _ := strconv.ParseFloat(strings.TrimSpace({varName}), 64); return val }()",
      "serialize": "strconv.FormatFloat({varName}, 'f', -1, 64)"
    },
    "c": {
      "typeName": "double",
      "library": "common/v1/c/common.h",
      "deserialize": "readDouble()",
      "serialize": "serializeDouble({varName})"
    }
  }
}
